<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="MaruHeaderStateTransition" name="마루 헤더 상태 전이" isExecutable="false">

    <!-- Start Event -->
    <bpmn:startEvent id="StartEvent_1" name="마루 헤더 생성">
      <bpmn:documentation>새로운 마루 헤더가 생성됩니다</bpmn:documentation>
      <bpmn:outgoing>Flow_StartToCreated</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- CREATED State -->
    <bpmn:userTask id="Task_Created" name="CREATED&#10;(생성상태)">
      <bpmn:documentation>초기 생성 상태
- 수정 가능
- 모든 필드 변경 허용
- 테스트 및 검증 단계</bpmn:documentation>
      <bpmn:incoming>Flow_StartToCreated</bpmn:incoming>
      <bpmn:incoming>Flow_InuseToCreated</bpmn:incoming>
      <bpmn:outgoing>Flow_CreatedToInuse</bpmn:outgoing>
      <bpmn:outgoing>Flow_CreatedToDeprecated</bpmn:outgoing>
    </bpmn:userTask>

    <!-- INUSE State -->
    <bpmn:userTask id="Task_Inuse" name="INUSE&#10;(사용중상태)">
      <bpmn:documentation>활성 사용 상태
- 제한적 수정 가능
- 운영 환경에서 사용 중
- 신중한 변경 필요</bpmn:documentation>
      <bpmn:incoming>Flow_CreatedToInuse</bpmn:incoming>
      <bpmn:outgoing>Flow_InuseToDeprecated</bpmn:outgoing>
      <bpmn:outgoing>Flow_InuseToCreated</bpmn:outgoing>
    </bpmn:userTask>

    <!-- DEPRECATED State -->
    <bpmn:userTask id="Task_Deprecated" name="DEPRECATED&#10;(폐기상태)">
      <bpmn:documentation>폐기 상태
- 읽기 전용
- 수정 불가
- 이력 관리용</bpmn:documentation>
      <bpmn:incoming>Flow_CreatedToDeprecated</bpmn:incoming>
      <bpmn:incoming>Flow_InuseToDeprecated</bpmn:incoming>
      <bpmn:outgoing>Flow_DeprecatedToEnd</bpmn:outgoing>
    </bpmn:userTask>

    <!-- End Event -->
    <bpmn:endEvent id="EndEvent_1" name="최종 상태">
      <bpmn:documentation>마루 헤더의 생명주기 종료</bpmn:documentation>
      <bpmn:incoming>Flow_DeprecatedToEnd</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <!-- Start to CREATED -->
    <bpmn:sequenceFlow id="Flow_StartToCreated" name="생성" sourceRef="StartEvent_1" targetRef="Task_Created">
      <bpmn:documentation>마루 헤더 최초 생성 시 CREATED 상태로 설정</bpmn:documentation>
    </bpmn:sequenceFlow>

    <!-- CREATED to INUSE -->
    <bpmn:sequenceFlow id="Flow_CreatedToInuse" name="활성화" sourceRef="Task_Created" targetRef="Task_Inuse">
      <bpmn:documentation>테스트 완료 후 운영 환경에서 사용 시작</bpmn:documentation>
    </bpmn:sequenceFlow>

    <!-- CREATED to DEPRECATED -->
    <bpmn:sequenceFlow id="Flow_CreatedToDeprecated" name="직접 폐기" sourceRef="Task_Created" targetRef="Task_Deprecated">
      <bpmn:documentation>테스트 결과 문제가 있어 사용하지 않고 바로 폐기</bpmn:documentation>
    </bpmn:sequenceFlow>

    <!-- INUSE to DEPRECATED -->
    <bpmn:sequenceFlow id="Flow_InuseToDeprecated" name="폐기" sourceRef="Task_Inuse" targetRef="Task_Deprecated">
      <bpmn:documentation>사용 중이던 마루 헤더를 폐기 처리</bpmn:documentation>
    </bpmn:sequenceFlow>

    <!-- INUSE to CREATED (conditional) -->
    <bpmn:sequenceFlow id="Flow_InuseToCreated" name="되돌리기&#10;(조건부)" sourceRef="Task_Inuse" targetRef="Task_Created">
      <bpmn:documentation>특별한 경우에만 허용되는 역방향 전환
- 중대한 결함 발견 시
- 긴급 수정이 필요한 경우</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">isEmergencyRollback == true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- DEPRECATED to END -->
    <bpmn:sequenceFlow id="Flow_DeprecatedToEnd" name="종료" sourceRef="Task_Deprecated" targetRef="EndEvent_1">
      <bpmn:documentation>폐기된 마루 헤더의 최종 상태</bpmn:documentation>
    </bpmn:sequenceFlow>

    <!-- Text Annotations for Additional Information -->
    <bpmn:textAnnotation id="TextAnnotation_StateRules">
      <bpmn:text>상태 전환 규칙:
• CREATED → INUSE → DEPRECATED (정상 흐름)
• CREATED → DEPRECATED (직접 폐기)
• INUSE → CREATED (긴급 시에만)</bpmn:text>
    </bpmn:textAnnotation>

    <bpmn:textAnnotation id="TextAnnotation_BusinessRules">
      <bpmn:text>비즈니스 규칙:
• 동일 마루ID에 대해 하나의 활성 버전만 존재
• 모든 상태 변경은 새로운 버전으로 관리
• DEPRECATED 상태에서는 읽기 전용</bpmn:text>
    </bpmn:textAnnotation>

    <!-- Association lines for annotations -->
    <bpmn:association id="Association_1" sourceRef="Task_Created" targetRef="TextAnnotation_StateRules" />
    <bpmn:association id="Association_2" sourceRef="Task_Deprecated" targetRef="TextAnnotation_BusinessRules" />

  </bpmn:process>

  <!-- Visual Layout (BPMN DI) -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="MaruHeaderStateTransition">

      <!-- Start Event -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="138" y="265" width="66" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- CREATED Task -->
      <bpmndi:BPMNShape id="Task_Created_di" bpmnElement="Task_Created" bioc:stroke="#43A047" bioc:fill="#C8E6C9">
        <dc:Bounds x="240" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- INUSE Task -->
      <bpmndi:BPMNShape id="Task_Inuse_di" bpmnElement="Task_Inuse" bioc:stroke="#1E88E5" bioc:fill="#BBDEFB">
        <dc:Bounds x="400" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- DEPRECATED Task -->
      <bpmndi:BPMNShape id="Task_Deprecated_di" bpmnElement="Task_Deprecated" bioc:stroke="#E53935" bioc:fill="#FFCDD2">
        <dc:Bounds x="560" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- End Event -->
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="712" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="708" y="265" width="44" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Text Annotations -->
      <bpmndi:BPMNShape id="TextAnnotation_StateRules_di" bpmnElement="TextAnnotation_StateRules">
        <dc:Bounds x="160" y="80" width="180" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_BusinessRules_di" bpmnElement="TextAnnotation_BusinessRules">
        <dc:Bounds x="520" y="80" width="180" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Sequence Flow Edges -->
      <!-- Start to CREATED -->
      <bpmndi:BPMNEdge id="Flow_StartToCreated_di" bpmnElement="Flow_StartToCreated">
        <di:waypoint x="188" y="240" />
        <di:waypoint x="240" y="240" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="204" y="222" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- CREATED to INUSE -->
      <bpmndi:BPMNEdge id="Flow_CreatedToInuse_di" bpmnElement="Flow_CreatedToInuse">
        <di:waypoint x="340" y="240" />
        <di:waypoint x="400" y="240" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="356" y="222" width="28" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- CREATED to DEPRECATED -->
      <bpmndi:BPMNEdge id="Flow_CreatedToDeprecated_di" bpmnElement="Flow_CreatedToDeprecated">
        <di:waypoint x="290" y="200" />
        <di:waypoint x="290" y="120" />
        <di:waypoint x="610" y="120" />
        <di:waypoint x="610" y="200" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="428" y="102" width="44" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- INUSE to DEPRECATED -->
      <bpmndi:BPMNEdge id="Flow_InuseToDeprecated_di" bpmnElement="Flow_InuseToDeprecated">
        <di:waypoint x="500" y="240" />
        <di:waypoint x="560" y="240" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="518" y="222" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- INUSE to CREATED (conditional) -->
      <bpmndi:BPMNEdge id="Flow_InuseToCreated_di" bpmnElement="Flow_InuseToCreated">
        <di:waypoint x="450" y="280" />
        <di:waypoint x="450" y="350" />
        <di:waypoint x="290" y="350" />
        <di:waypoint x="290" y="280" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="354" y="332" width="32" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- DEPRECATED to END -->
      <bpmndi:BPMNEdge id="Flow_DeprecatedToEnd_di" bpmnElement="Flow_DeprecatedToEnd">
        <di:waypoint x="660" y="240" />
        <di:waypoint x="712" y="240" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="676" y="222" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Association Edges -->
      <bpmndi:BPMNEdge id="Association_1_di" bpmnElement="Association_1">
        <di:waypoint x="270" y="200" />
        <di:waypoint x="250" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_2_di" bpmnElement="Association_2">
        <di:waypoint x="610" y="200" />
        <di:waypoint x="610" y="160" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>