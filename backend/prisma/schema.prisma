// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  passwordHash  String    @map("password_hash")
  role          String    @default("user")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  assignedIssues Issue[]
  terminalLogs   TerminalLog[]
  projectMembers ProjectMember[]

  @@map("users")
}

model Project {
  id          String   @id @default(uuid())
  name        String
  key         String   @unique
  description String?
  rootPath    String   @map("root_path")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  issues          Issue[]
  promptTemplates PromptTemplate[]
  members         ProjectMember[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   @default("member")
  joinedAt  DateTime @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_members")
}

model Issue {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  type        String   // Epic, Feature, Task, Bug, etc.
  parentId    String?  @map("parent_id")
  title       String
  description String?
  status      String
  assigneeId  String?  @map("assignee_id")
  priority    String   @default("medium")
  docPath     String?  @map("doc_path")
  branchName  String?  @map("branch_name")
  customFields Json    @default("{}") @map("custom_fields")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  project      Project        @relation(fields: [projectId], references: [id])
  parent       Issue?         @relation("IssueToIssue", fields: [parentId], references: [id])
  children     Issue[]        @relation("IssueToIssue")
  assignee     User?          @relation(fields: [assigneeId], references: [id])
  terminalLogs TerminalLog[]
  workflowJobs WorkflowJob[]

  @@map("issues")
}

model PromptTemplate {
  id             String   @id @default(uuid())
  projectId      String?  @map("project_id")
  name           String
  description    String?
  prompt         String   @db.Text
  llmType        String   @map("llm_type")
  visibleColumns String[] @map("visible_columns")
  visibleTypes   String[] @map("visible_types")
  variables      Json     @default("{}")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  project      Project?       @relation(fields: [projectId], references: [id])
  terminalLogs TerminalLog[]
  workflowSteps WorkflowStep[]

  @@map("prompt_templates")
}

model TerminalLog {
  id         String    @id @default(uuid())
  issueId    String?   @map("issue_id")
  templateId String?   @map("template_id")
  userId     String?   @map("user_id")
  sessionId  String?   @map("session_id")
  inputLog   String?   @db.Text @map("input_log")
  outputLog  String?   @db.Text @map("output_log")
  status     String?
  startedAt  DateTime  @default(now()) @map("started_at")
  endedAt    DateTime? @map("ended_at")

  // Relations
  issue    Issue?          @relation(fields: [issueId], references: [id])
  template PromptTemplate? @relation(fields: [templateId], references: [id])
  user     User?           @relation(fields: [userId], references: [id])
  workflowSteps WorkflowStep[]

  @@map("terminal_logs")
}

model WorkflowJob {
  id               String   @id @default(uuid())
  issueId          String   @map("issue_id")
  status           String   // running, paused, completed, failed
  currentStepIndex Int      @default(0) @map("current_step_index")
  isAutoMode       Boolean  @default(false) @map("is_auto_mode")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  issue Issue          @relation(fields: [issueId], references: [id])
  steps WorkflowStep[]

  @@map("workflow_jobs")
}

model WorkflowStep {
  id            String    @id @default(uuid())
  jobId         String    @map("job_id")
  stepName      String    @map("step_name")
  status        String    // pending, running, success, failed, waiting_approval
  templateId    String?   @map("template_id")
  terminalLogId String?   @map("terminal_log_id")
  resultSummary String?   @db.Text @map("result_summary")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")

  // Relations
  job         WorkflowJob     @relation(fields: [jobId], references: [id])
  template    PromptTemplate? @relation(fields: [templateId], references: [id])
  terminalLog TerminalLog?    @relation(fields: [terminalLogId], references: [id])

  @@map("workflow_steps")
}
